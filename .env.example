# LLM Configuration
# For local Ollama:
# LLM_MODEL=ollama/llama3.2
# OLLAMA_API_BASE=http://localhost:11434

# For OpenAI:
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# For Anthropic:
# LLM_MODEL=anthropic/claude-sonnet-4-20250514
# ANTHROPIC_API_KEY=sk-ant-...

LLM_MODEL=ollama/llama3.2
LLM_TEMPERATURE=0.3
# Number of concurrent LLM requests (matches Ollama's OLLAMA_NUM_PARALLEL, default 4)
LLM_MAX_CONCURRENT=4

# TTS Configuration
# Options: edge-tts, kokoro, openai-tts
TTS_PROVIDER=edge-tts
TTS_VOICE=en-US-AriaNeural

# OpenAI TTS (if using openai-tts provider)
# OPENAI_TTS_VOICE=nova
# OPENAI_API_KEY=sk-...
